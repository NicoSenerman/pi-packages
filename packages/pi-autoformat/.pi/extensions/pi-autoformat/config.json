{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-autoformat/main/schemas/pi-autoformat.schema.json",
  "formatMode": "prompt",
  "hideSummariesInTui": false,
  "formatters": {
    "biome": {
      "command": [
        "pnpm",
        "exec",
        "biome",
        "check",
        "--write",
        "--files-ignore-unknown=true"
      ]
    },
    "rumdl": {
      "command": ["rumdl", "--fix"]
    }
  },
  "chains": {
    ".ts": ["biome"],
    ".json": ["biome"],
    ".md": ["rumdl"]
  }
}
